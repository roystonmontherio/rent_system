# ============================================
# 🔄 ENVIRONMENT SWITCH
# Set MODE to "local" or "production"
# ============================================
MODE=local

PORT=5000
NODE_ENV=development

# 🗄️ LOCAL Database
LOCAL_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/rent_system

# 🗄️ PRODUCTION Database (Supabase)
PROD_DATABASE_URL=postgresql://your_user:your_password@your_host:5432/postgres

# 🔐 Security
JWT_SECRET=change_me_to_a_random_secret
JWT_EXPIRES_IN=7d

# 📱 Fast2SMS OTP
FAST2SMS_API_KEY=your_fast2sms_api_key

# 🔥 Firebase Service Account (JSON string)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your_project"}'
